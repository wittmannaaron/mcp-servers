# Environment variables for file-catalog

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/filecatalog.log
LOG_FILE_ROTATION=10 MB
LOG_FILE_RETENTION=10 days

# File Processing Settings
MAX_FILE_SIZE_MB=100

# Database Settings
DATABASE_URL=sqlite:///./data/filecatalog.db

# Ollama LLM Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
LLM_REQUEST_TIMEOUT=60.0
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# Processing Tool Preferences
PREFER_MARKITDOWN=true
PREFER_PANDOC=true
USE_DOCLING_PDF_ONLY=true