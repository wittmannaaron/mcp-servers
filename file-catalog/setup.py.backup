#!/usr/bin/env python3
"""
Quick setup and verification script for file-catalog.
"""

import subprocess
import sys
from pathlib import Path

def run_command(cmd, description):
    """Run a command and return success status."""
    print(f"🔧 {description}...")
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        if result.returncode == 0:
            print(f"✅ {description} successful")
            return True
        else:
            print(f"❌ {description} failed: {result.stderr}")
            return False
    except Exception as e:
        print(f"❌ {description} failed: {e}")
        return False

def check_tool_availability():
    """Check if external tools are available."""
    print("\n🛠️  Checking Tool Availability")
    print("=" * 50)
    
    tools = {
        "python": "python --version",
        "ollama": "ollama --version", 
        "pandoc": "pandoc --version",
        "exiftool": "exiftool -ver"
    }
    
    results = {}
    for tool, cmd in tools.items():
        try:
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
            if result.returncode == 0:
                version = result.stdout.strip().split('\n')[0]
                print(f"✅ {tool}: {version}")
                results[tool] = True
            else:
                print(f"❌ {tool}: Not available")
                results[tool] = False
        except Exception:
            print(f"❌ {tool}: Not available")
            results[tool] = False
    
    return results

def setup_project():
    """Set up the project environment."""
    print("\n🚀 Setting up file-catalog")
    print("=" * 50)
    
    project_root = Path(__file__).parent
    
    # Check if virtual environment exists
    venv_path = project_root / "venv"
    if not venv_path.exists():
        print("📦 Creating virtual environment...")
        if not run_command("python -m venv venv", "Virtual environment creation"):
            return False
    
    # Check if .env exists
    env_file = project_root / ".env"
    if not env_file.exists():
        env_example = project_root / ".env.example"
        if env_example.exists():
            print("📝 Copying .env.example to .env...")
            run_command("cp .env.example .env", "Environment file setup")
        else:
            print("⚠️  .env.example not found")
    
    # Create necessary directories
    dirs_to_create = ["data", "logs"]
    for dir_name in dirs_to_create:
        dir_path = project_root / dir_name
        if not dir_path.exists():
            print(f"📁 Creating {dir_name} directory...")
            dir_path.mkdir(exist_ok=True)
    
    print("\n✅ Project setup complete!")
    return True

def show_next_steps():
    """Show next steps for the user."""
    print("\n📋 Next Steps")
    print("=" * 50)
    print("""
1. Activate virtual environment:
   source venv/bin/activate

2. Install dependencies:
   pip install -r requirements.txt

3. Install external tools (if needed):
   # macOS with Homebrew:
   brew install pandoc exiftool
   
   # markitdown via pip:
   pip install markitdown

4. Set up Ollama:
   # Install Ollama
   curl -fsSL https://ollama.ai/install.sh | sh
   
   # Pull required models
   ollama pull llama3.2:latest
   ollama pull bge-m3

5. Configure environment:
   # Edit .env file with your settings
   nano .env

6. Test the setup:
   python full_ingestion_test.py --check-tools

7. Run ingestion test:
   python full_ingestion_test.py -c 5 -d /path/to/your/documents

8. Monitor with DBeaver or sqlite3:
   sqlite3 data/filecatalog.db
""")

def main():
    """Main setup function."""
    print("🎯 File Catalog Setup & Verification")
    print("=" * 50)
    
    # Check tool availability
    tools = check_tool_availability()
    
    # Setup project
    if setup_project():
        show_next_steps()
        
        # Summary
        print("\n📊 Setup Summary")
        print("=" * 50)
        print("✅ Project structure created")
        print("✅ Configuration files ready")
        
        missing_tools = [tool for tool, available in tools.items() if not available]
        if missing_tools:
            print(f"⚠️  Missing tools: {', '.join(missing_tools)}")
            print("   Install them for full functionality")
        else:
            print("✅ All tools available")
        
        print("\n🎉 file-catalog is ready to use!")
        print("\nRun: python full_ingestion_test.py --check-tools")
    else:
        print("\n❌ Setup failed")
        sys.exit(1)

if __name__ == "__main__":
    main()